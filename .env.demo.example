PRIVATE_KEY=0xabc123...

# Demo submission slot 1
DEMO_CLAIM_1_PRIVATE_KEY=0xdef456...
DEMO_CLAIM_1_NAME=Submission 1 - Blue object photo
DEMO_CLAIM_1_DESCRIPTION=Photo submission from wallet 1 showing a blue object outdoors.
DEMO_CLAIM_1_PROOF_URI=https://example.com/blue-proof-a.jpg
DEMO_CLAIM_1_EXPECTED_CLAIMANT_ADDRESS=

# Demo submission slot 2
DEMO_CLAIM_2_PRIVATE_KEY=0x789abc...
DEMO_CLAIM_2_NAME=Submission 2 - Blue object photo
DEMO_CLAIM_2_DESCRIPTION=Photo submission from wallet 2 showing a different blue object outdoors.
DEMO_CLAIM_2_PROOF_URI=https://example.com/blue-proof-b.jpg
DEMO_CLAIM_2_EXPECTED_CLAIMANT_ADDRESS=
RPC_URL=https://arb1.arbitrum.io/rpc
POIDH_CHAIN=arbitrum

# Optional, used for automated public updates
SOCIAL_POST_WEBHOOK_URL=
SOCIAL_POST_AUTHOR=0x94t3z.eth
SOCIAL_POST_TARGETS=x,farcaster

# Optional, remembers the last bounty ID after restart
BOUNTY_STATE_FILE=.poidh-state.json

# Optional, used if you want an LLM-based review path later
OPENAI_API_KEY=
OPENAI_MODEL=

# Bot defaults
POLL_INTERVAL_MS=60000
AUTO_ACCEPT=true
AUTO_SUBMIT_CLAIM=true
BOUNTY_KIND=solo
BOUNTY_NAME=Take a photo of something blue outdoors
BOUNTY_DESCRIPTION=Upload a clear outdoor photo of something blue.
# Poidh's minimum bounty amount on Arbitrum/Base is 0.001 ETH.
BOUNTY_AMOUNT_ETH=0.001
ARTIFACT_DIR=artifacts/demo
