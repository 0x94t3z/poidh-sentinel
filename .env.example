PRIVATE_KEY=0xabc123...
RPC_URL=https://arb1.arbitrum.io/rpc
POIDH_CHAIN=arbitrum

# Optional, used for automated public updates
SOCIAL_POST_WEBHOOK_URL=http://127.0.0.1:8787/decision
SOCIAL_POST_AUTHOR=
RELAY_PORT=8787
RELAY_OUTPUT_DIR=artifacts/relay
NEYNAR_API_KEY=
FARCASTER_SIGNER_UUID=
FARCASTER_CHANNEL_ID=poidh
NEYNAR_WEBHOOK_SECRET=


# Optional, remembers the last bounty ID after restart
BOUNTY_STATE_FILE=.poidh-state.json

# Optional, used to polish Farcaster copy with OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Bot defaults
POLL_INTERVAL_MS=60000
AUTO_FINALIZE_WINNER=true
# Require at least this many claims before final on-chain accept/vote action.
MIN_PARTICIPANTS_BEFORE_FINALIZE=1
# Wait this long (in seconds) after the first observed claim before final action.
# This is a bot-side safety delay, not Poidh's own bounty end timer.
FIRST_CLAIM_COOLDOWN_SECONDS=0
BOUNTY_KIND=solo
BOUNTY_NAME=Take a photo of something blue outdoors
BOUNTY_DESCRIPTION=Upload a clear outdoor photo of something blue.
# Poidh's minimum bounty amount on Arbitrum/Base is 0.001 ETH.
BOUNTY_AMOUNT_ETH=0.001
ARTIFACT_DIR=artifacts/production
