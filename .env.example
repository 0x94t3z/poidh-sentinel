# Required
DATABASE_URL=
NEYNAR_API_KEY=
BOT_SIGNER_UUID=
BOT_WALLET_PRIVATE_KEY=
BOT_WALLET_ADDRESS=

# Recommended
NEYNAR_WEBHOOK_SECRET=
GROQ_API_KEY=

# Optional — tier 1 agent replies, tier 2 claim eval (~2000 tok/s)
CEREBRAS_API_KEY=

# Optional — tier 2 vision fallback (gpt-4o-mini, excellent text reading)
OPENAI_API_KEY=

# Optional — tier 3 fallback for LLM and vision (free models)
OPENROUTER_API_KEY=

# Optional — defaults to public helloworld key if unset
OCR_SPACE_API_KEY=

# Optional — custom RPCs (hardcoded defaults exist)
ARBITRUM_RPC_URL=
BASE_RPC_URL=

# Optional — secures the cron endpoint
CRON_SECRET=

# Optional — public app config (avoids local config warnings)
NEXT_PUBLIC_USER_FID=3273077
BOT_FID=3273077
# Use one canonical public URL in production
NEXT_PUBLIC_BASE_URL=
# Local/public hostname fallbacks used by public-config
NEXT_PUBLIC_LOCAL_URL=
NEXT_PUBLIC_VERCEL_PRODUCTION_URL=
# Optional webhook URL exposed in mini-app metadata
WEBHOOK_URL=
