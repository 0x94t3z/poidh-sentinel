BOT_PRIVATE_KEY=0xabc123...
CHAIN_RPC_URL=https://arb1.arbitrum.io/rpc
TARGET_CHAIN=arbitrum

# Optional, used for automated public updates
DECISION_WEBHOOK_URL=http://127.0.0.1:8787/decision
SOCIAL_AUTHOR=
RELAY_LISTEN_PORT=8787
RELAY_ARTIFACT_DIR=artifacts/relay
NEYNAR_API_KEY=
FARCASTER_SIGNER_UUID=
FARCASTER_CHANNEL_ID=poidh
WEBHOOK_SIGNATURE_SECRET=
BOT_FARCASTER_HANDLE=poidh-sentinel
# Optional: used to ignore self-authored mention webhooks if you know the bot FID
BOT_FID=
# Allow replying to general @mentions outside tracked bounty threads (requires webhook delivery)
ENABLE_GENERAL_MENTION_REPLIES=false
# Allow /assistant endpoint to create open bounties on-chain
ASSISTANT_ENABLE_CREATE_OPEN_BOUNTY=false

# Optional, remembers the last bounty ID after restart
BOT_STATE_FILE=.poidh-state.json

# Optional AI API keys
CEREBRAS_API_KEY=
# OpenRouter remains the fallback if Cerebras is unavailable
OPENROUTER_API_KEY=
# Winner evaluation mode: deterministic | ai_hybrid | ai_required
WINNER_EVALUATION_MODE=ai_hybrid
# Minimum AI confidence (0..1) required to accept a claim in AI modes
AI_EVALUATION_MIN_CONFIDENCE=0.70
# Let AI inspect provided image URLs during winner evaluation
AI_EVALUATION_ENABLE_VISION=false
# Let AI fetch and inspect external links found in claim description/evidence text
AI_EVALUATION_INSPECT_LINKS=true
# Max number of external links to inspect per claim
AI_EVALUATION_MAX_LINKS=2

# Bot defaults
WATCH_POLL_INTERVAL_MS=60000
AUTO_FINALIZE_WINNER=false
# Require at least this many claims before final on-chain accept/vote action.
MIN_PARTICIPANTS_BEFORE_FINALIZE=2
# Wait this long (in seconds) after the first observed claim before final action.
# This is a bot-side safety delay, not Poidh's own bounty end timer.
FIRST_CLAIM_COOLDOWN_SECONDS=3600
# Optional one-shot scheduler pacing (used by `scheduled-flow`)
SCHEDULE_STAGE_DELAY_MS=15000
SCHEDULE_MAX_LOGGED_CLAIMS=10
BOUNTY_MODE=open
BOUNTY_TITLE=Photo of a handwritten note with today’s date
BOUNTY_PROMPT=Upload a clear outdoor photo of a handwritten note that says today’s full date, your username, and the word poidh.
# Poidh's minimum bounty amount on Arbitrum/Base is 0.001 ETH.
BOUNTY_REWARD_ETH=0.001
PRODUCTION_ARTIFACT_DIR=artifacts/production
